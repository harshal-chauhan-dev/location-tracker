{
  "name": "location-trackers",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "oidc": "bun run --watch oidc-server.js",
    "tracker": "bun run --watch location-tracker-server.js",
    "db:processor": "bun run src/modules/location-tracker/database-processor.js",
    "db:generate": "drizzle-kit generate",
